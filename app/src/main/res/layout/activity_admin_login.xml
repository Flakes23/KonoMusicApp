<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/admin_primary"
    android:gravity="center">

    <!-- Logo / Title Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <!-- App Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♪"
            android:textSize="56sp"
            android:textColor="@color/admin_accent"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KonoMusic Admin"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/admin_text_primary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Your Music"
            android:textSize="14sp"
            android:textColor="@color/admin_text_secondary"
            android:gravity="center" />

    </LinearLayout>

    <!-- Form Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Email Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/edit_text_bg_dark"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉"
                android:textSize="20sp"
                android:textColor="@color/admin_text_secondary"
                android:layout_marginRight="12dp" />

            <EditText
                android:id="@+id/admin_edit_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Email address"
                android:inputType="textEmailAddress"
                android:textColor="@color/admin_text_primary"
                android:textColorHint="@color/admin_text_tertiary"
                android:textSize="14sp"
                android:background="@null"
                android:paddingLeft="0dp"
                android:paddingRight="0dp" />

        </LinearLayout>

        <!-- Password Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/edit_text_bg_dark"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="20sp"
                android:textColor="@color/admin_text_secondary"
                android:layout_marginRight="12dp" />

            <EditText
                android:id="@+id/admin_edit_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColor="@color/admin_text_primary"
                android:textColorHint="@color/admin_text_tertiary"
                android:textSize="14sp"
                android:background="@null"
                android:paddingLeft="0dp"
                android:paddingRight="0dp" />

        </LinearLayout>

        <!-- Login Button -->
        <Button
            android:id="@+id/admin_btn_login"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="LOGIN"
            android:textColor="@color/admin_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary_green"
            android:layout_marginBottom="16dp"
            android:stateListAnimator="@null" />

        <!-- Remember Me Checkbox -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remember me"
            android:textSize="12sp"
            android:textColor="@color/admin_text_secondary" />

    </LinearLayout>

    <!-- Demo Info Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg_gradient"
        android:padding="16dp"
        android:layout_marginTop="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Demo Credentials"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/admin_accent"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email: admin@konomusic.com"
            android:textSize="12sp"
            android:textColor="@color/admin_text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password: admin123"
            android:textSize="12sp"
            android:textColor="@color/admin_text_primary" />

    </LinearLayout>

</LinearLayout>



