<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/admin_card_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Icon + Trend badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_stat_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar_circle"
                android:padding="9dp"
                android:src="@drawable/ic_music_note"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tv_trend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+5%"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_avatar_circle"/>

            <!-- hidden view used by adapter for tint -->
            <View
                android:id="@+id/ll_trend"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Row 2: Big number -->
        <TextView
            android:id="@+id/tv_stat_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:singleLine="true"/>

        <!-- Row 3: Label -->
        <TextView
            android:id="@+id/tv_stat_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Label"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:singleLine="true"/>

        <!-- Accent line -->
        <View
            android:id="@+id/accent_line"
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="12dp"
            android:background="@color/admin_accent"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
