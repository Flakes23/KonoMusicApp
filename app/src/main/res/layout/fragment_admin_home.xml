<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Welcome Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/text_admin_welcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome back!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/admin_text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage your music and content"
                android:textSize="14sp"
                android:textColor="@color/admin_text_secondary" />

        </LinearLayout>

        <!-- Quick Stats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <!-- Stat Card 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_gradient"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginRight="8dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📹"
                    android:textSize="28sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1,234"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/admin_text_primary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Videos"
                    android:textSize="12sp"
                    android:textColor="@color/admin_text_secondary" />

            </LinearLayout>

            <!-- Stat Card 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_gradient"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginRight="8dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥"
                    android:textSize="28sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5,678"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/admin_text_primary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Users"
                    android:textSize="12sp"
                    android:textColor="@color/admin_text_secondary" />

            </LinearLayout>

            <!-- Stat Card 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_gradient"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎵"
                    android:textSize="28sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="890"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/admin_text_primary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tracks"
                    android:textSize="12sp"
                    android:textColor="@color/admin_text_secondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Cards Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/admin_text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Submit Video Card -->
        <LinearLayout
            android:id="@+id/card_submit_video"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg_gradient"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📹"
                    android:textSize="32sp"
                    android:layout_marginRight="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Submit Video"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/admin_text_primary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Add new video content"
                        android:textSize="12sp"
                        android:textColor="@color/admin_text_secondary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="24sp"
                    android:textColor="@color/admin_accent" />

            </LinearLayout>

        </LinearLayout>

        <!-- Manage Curation Card -->
        <LinearLayout
            android:id="@+id/card_manage_curation"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg_gradient"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="32sp"
                    android:layout_marginRight="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Curation"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/admin_text_primary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Review and approve content"
                        android:textSize="12sp"
                        android:textColor="@color/admin_text_secondary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="24sp"
                    android:textColor="@color/admin_accent" />

            </LinearLayout>

        </LinearLayout>

        <!-- Analytics Card -->
        <LinearLayout
            android:id="@+id/card_analytics"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg_gradient"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:elevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="32sp"
                    android:layout_marginRight="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Analytics"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/admin_text_primary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View statistics and insights"
                        android:textSize="12sp"
                        android:textColor="@color/admin_text_secondary" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="24sp"
                    android:textColor="@color/admin_accent" />

            </LinearLayout>

        </LinearLayout>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btn_admin_logout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="LOGOUT"
            android:textColor="@color/admin_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:layout_marginBottom="16dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>


