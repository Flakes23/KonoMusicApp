<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Total Videos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Videos"
            android:textSize="14sp"
            android:textColor="@color/gray" />

        <TextView
            android:id="@+id/text_total_videos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="150"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

    </LinearLayout>

    <!-- Total Plays -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Plays"
            android:textSize="14sp"
            android:textColor="@color/gray" />

        <TextView
            android:id="@+id/text_total_plays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50,000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

    </LinearLayout>

    <!-- Active Users -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Active Users"
            android:textSize="14sp"
            android:textColor="@color/gray" />

        <TextView
            android:id="@+id/text_active_users"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1,200"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

    </LinearLayout>

    <!-- Top Video -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_bg">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Top Video"
            android:textSize="14sp"
            android:textColor="@color/gray" />

        <TextView
            android:id="@+id/text_top_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Never Gonna Give You Up"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

    </LinearLayout>

</LinearLayout>

