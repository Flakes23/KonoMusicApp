<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KonoMusic"
        android:name=".KonoMusicApp">

        <!-- Admin Login Activity -->
        <activity
            android:name=".admin.ui.activities.AdminLoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Admin Main Activity -->
        <activity
            android:name=".admin.ui.activities.AdminMainActivity"
            android:exported="true" />

        <!-- Submit Video Activity -->
        <activity
            android:name=".admin.ui.activities.SubmitVideoActivity"
            android:exported="true" />

        <!-- Manage Curation Activity -->
        <activity
            android:name=".admin.ui.activities.ManageCurationActivity"
            android:exported="true" />

        <!-- View Analytics Activity -->
        <activity
            android:name=".admin.ui.activities.ViewAnalyticsActivity"
            android:exported="true" />

    </application>

</manifest>

