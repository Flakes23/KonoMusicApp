<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Video for Curation"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- YouTube ID -->
            <EditText
                android:id="@+id/edit_youtube_id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="YouTube Video ID"
                android:padding="12dp"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="12dp" />

            <!-- Title -->
            <EditText
                android:id="@+id/edit_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Video Title"
                android:padding="12dp"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="12dp" />

            <!-- Channel Name -->
            <EditText
                android:id="@+id/edit_channel_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Channel Name"
                android:padding="12dp"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="12dp" />

            <!-- Genre Spinner -->
            <Spinner
                android:id="@+id/spinner_genre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp" />

            <!-- Note -->
            <EditText
                android:id="@+id/edit_note"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Additional Notes"
                android:padding="12dp"
                android:gravity="top"
                android:background="@drawable/edit_text_bg"
                android:layout_marginBottom="12dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_submit_video"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Submit"
            android:textColor="@color/white"
            android:background="@drawable/btn_submit_bg"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@color/white"
            android:background="@drawable/btn_cancel_bg" />

    </LinearLayout>

</LinearLayout>

