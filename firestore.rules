rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public music catalog: guest can browse and play songs.
    match /songs/{songId} {
      allow read: if true;

      // Client can only bump playCount (optionally with updatedAt), never edit other fields.
      allow update: if request.resource.data.diff(resource.data).changedKeys()
                      .hasOnly(['playCount', 'updatedAt'])
                    && request.resource.data.playCount is int
                    && request.resource.data.playCount >= resource.data.playCount;

      allow create, delete: if false;
    }

    // Public metadata for app sections.
    match /albums/{albumId} {
      allow read: if true;
      allow write: if false;
    }

    match /artists/{artistId} {
      allow read: if true;
      allow write: if false;
    }

    match /genres/{genreId} {
      allow read: if true;
      allow write: if false;
    }

    // User profile and personal data.
    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /favorites/{songId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /playlists/{playlistId} {
        allow read, create, update, delete: if isOwner(uid);

        // Optional: support per-track subcollection when you need ordering metadata.
        match /tracks/{trackId} {
          allow read, create, update, delete: if isOwner(uid);
        }
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

