<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_admin_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== HEADER GREETING ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xin chào, Admin! 👋"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Tổng quan hệ thống"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_last_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cập nhật lúc: 09:30 SA, 05/03/2026"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_header_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_person_add"
                android:background="@drawable/bg_avatar_circle"
                android:padding="12dp"
                app:civ_border_color="#AAFFFFFF"
                app:civ_border_width="2dp"/>
        </LinearLayout>

        <!-- ===== STAT CARDS GRID ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:text="📊 Thống kê tổng quan"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_stat_cards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

        <!-- ===== QUICK ACTIONS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:text="⚡ Thao tác nhanh"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:id="@+id/action_add_song"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_quick_action"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    android:backgroundTint="@color/stat_songs"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Thêm\nBài hát"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/action_add_artist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_quick_action"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_artist"
                    android:backgroundTint="@color/stat_artists"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Thêm\nNghệ sĩ"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/action_add_album"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_quick_action"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_album"
                    android:backgroundTint="@color/stat_albums"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Thêm\nAlbum"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/action_manage_users"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_quick_action"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_people"
                    android:backgroundTint="@color/stat_users"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Quản lý\nUsers"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== GENRE CHART ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎵 Phân bố thể loại nhạc"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tháng 3/2026"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@color/divider_color"/>

            <!-- Pop -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Pop" android:textColor="@color/white" android:textSize="13sp"/>
                <ProgressBar android:id="@+id/pb_pop"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1" android:max="100" android:progress="72"
                    android:progressTint="@color/genre_pop"
                    android:progressBackgroundTint="#2FFFFFFF"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="72%" android:textColor="@color/genre_pop" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Rock -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Rock" android:textColor="@color/white" android:textSize="13sp"/>
                <ProgressBar android:id="@+id/pb_rock"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1" android:max="100" android:progress="58"
                    android:progressTint="@color/genre_rock"
                    android:progressBackgroundTint="#2FFFFFFF"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="58%" android:textColor="@color/genre_rock" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Hip-hop -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Hip-hop" android:textColor="@color/white" android:textSize="13sp"/>
                <ProgressBar android:id="@+id/pb_hiphop"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1" android:max="100" android:progress="45"
                    android:progressTint="@color/genre_hiphop"
                    android:progressBackgroundTint="#2FFFFFFF"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="45%" android:textColor="@color/genre_hiphop" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Jazz -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="Jazz" android:textColor="@color/white" android:textSize="13sp"/>
                <ProgressBar android:id="@+id/pb_jazz"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1" android:max="100" android:progress="31"
                    android:progressTint="@color/genre_jazz"
                    android:progressBackgroundTint="#2FFFFFFF"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="31%" android:textColor="@color/genre_jazz" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- EDM -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                    android:text="EDM" android:textColor="@color/white" android:textSize="13sp"/>
                <ProgressBar android:id="@+id/pb_edm"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp"
                    android:layout_weight="1" android:max="100" android:progress="89"
                    android:progressTint="@color/genre_edm"
                    android:progressBackgroundTint="#2FFFFFFF"/>
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="89%" android:textColor="@color/genre_edm" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== RECENT ACTIVITY ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🕐 Hoạt động gần đây"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả →"
                android:textColor="@color/admin_accent"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recent_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"/>

        <!-- ===== TOP SONGS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔥 Bài hát thịnh hành"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top 5 hôm nay"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top_songs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

